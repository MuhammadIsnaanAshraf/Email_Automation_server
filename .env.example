# ─────────────────────────────────────────────────────────────
# FlowState backend — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Where the React frontend runs (used for CORS + post-login redirect)
FRONTEND_URL=http://localhost:5173

# Public base URL of THIS backend (used to build the OAuth redirect URI)
BACKEND_URL=http://localhost:4000

# ── Google OAuth (Google Cloud Console → APIs & Services → Credentials) ──
# Create an "OAuth 2.0 Client ID" of type "Web application".
# Add this exact redirect URI in the console:
#   http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Supabase (Project Settings → API) ──
# Use the SERVICE ROLE key on the backend only. Never expose it to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App secrets ──
# 32-byte key (hex, 64 chars) used to encrypt Google refresh tokens at rest.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars

# How long a login session lasts, in days
SESSION_TTL_DAYS=30

# ─────────────────────────────────────────────────────────────
# Module 4 — Sending Engine (Supabase Edge Function secrets)
# These are NOT used by the Express server. Set them on the Edge Function with:
#   supabase secrets set KEY=value
# The Edge Function also needs SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
# GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, and TOKEN_ENCRYPTION_KEY (same values
# as above — TOKEN_ENCRYPTION_KEY MUST match so it can decrypt refresh tokens).
# ─────────────────────────────────────────────────────────────
# Shared secret pg_cron sends in the `x-tick-secret` header to authorize a tick.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SEND_TICK_SECRET=replace-with-64-hex-chars
# Throttling knobs (safe defaults shown):
SEND_MAX_PER_PASS=200               # ceiling for a whole tick
SEND_MAX_PER_USER_PER_PASS=5        # anti-burst cap per account per tick
SEND_INTRA_PASS_DELAY_MS=8000       # gap between one account's sends in a pass
SEND_DEFAULT_DAILY_LIMIT=400        # per-account/day fallback (also users.daily_send_limit)
SEND_MAX_ATTEMPTS=5                 # retries before a transient failure is marked failed
